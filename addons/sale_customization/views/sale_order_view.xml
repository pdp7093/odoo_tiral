<odoo>
    <record id="sale_order_form_inherit_approval" model="ir.ui.view">
        <field name="name">sale.order.form.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"></field>
        <field name="arch" type="xml" > 
            <xpath expr="//header" position="inside" >
                <button name="action_manager_approve" type="object"
                string="Manager Approve" class="btn btn-primary"
                invisible="state != 'waiting_approval'" />
            </xpath>
        </field>
    </record>
</odoo>